# -------------------------------
# Stage 1: Build the Go binary
# -------------------------------
FROM golang:1.24 AS builder

# Set the working directory inside the container
WORKDIR /app

# Copy go mod and sum files from project root (one level up)
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy the entire project source (from project root)
COPY . .

# Build the Go binary (static build for small image)
RUN CGO_ENABLED=0 GOOS=linux go build -o main .

# -------------------------------
# Stage 2: Create a minimal image
# -------------------------------
FROM alpine:latest

# Set working directory
WORKDIR /root/

# Copy binary from builder
COPY --from=builder /app/main .

# Expose port (change if your app uses another port)
EXPOSE 8080

# Command to run the executable
CMD ["./main"]
# -------------------------------